generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Con Supabase se necesitan DOS strings:
  //   - url            → conexión con pgbouncer (pooling) para queries en runtime
  //   - directUrl      → conexión directa para prisma migrate / prisma db push
  // En desarrollo local (Docker) ambas pueden ser la misma.
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum ComponentType {
  CPU
  MOTHERBOARD
  MEMORY
  STORAGE
  GPU
  PSU
  CASE
}

enum MemoryType {
  DDR4
  DDR5
}

enum StorageInterface {
  M2_NVME
  SATA
}

enum FormFactor {
  MINI_ITX
  MATX
  ATX
  E_ATX
  XL_ATX
}

enum PsuEfficiency {
  BRONZE_80PLUS
  GOLD_80PLUS
  PLATINUM_80PLUS
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────────────────────────
// Productos
// ─────────────────────────────────────────────────────────────

model Product {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  brand         String
  description   String
  image         String
  stock         Int           @default(0)
  priceCents    Int
  componentType ComponentType
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  cpuSpec         CpuSpec?
  motherboardSpec MotherboardSpec?
  memorySpec      MemorySpec?
  storageSpec     StorageSpec?
  gpuSpec         GpuSpec?
  psuSpec         PsuSpec?
  caseSpec        CaseSpec?
  cartItems       CartItem[]
  orderItems      OrderItem[]
}

model CpuSpec {
  productId String @id
  socket    String
  cores     Int
  threads   Int
  tdpWatts  Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model MotherboardSpec {
  productId   String     @id
  socket      String
  formFactor  FormFactor
  memoryType  MemoryType
  maxMemoryGb Int
  m2Slots     Int
  sataPorts   Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model MemorySpec {
  productId  String     @id
  memoryType MemoryType
  speedMhz   Int
  capacityGb Int
  modules    Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model StorageSpec {
  productId  String           @id
  interface  StorageInterface
  capacityGb Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model GpuSpec {
  productId String @id
  vramGb    Int
  tdpWatts  Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PsuSpec {
  productId  String        @id
  wattage    Int
  efficiency PsuEfficiency

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model CaseSpec {
  productId            String     @id
  supportedFormFactors FormFactor[]

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Carrito
// ─────────────────────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

// ─────────────────────────────────────────────────────────────
// Pedidos
// ─────────────────────────────────────────────────────────────

model Order {
  id                    String      @id @default(cuid())
  stripePaymentIntentId String?     @unique
  stripeSessionId       String?     @unique
  status                OrderStatus @default(PENDING)
  totalCents            Int
  currency              String      @default("eur")
  customerEmail         String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  items OrderItem[]
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  priceCents Int    // precio en el momento de la compra

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// FAQ
// ─────────────────────────────────────────────────────────────

model FaqEntry {
  id        String   @id @default(cuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
}
