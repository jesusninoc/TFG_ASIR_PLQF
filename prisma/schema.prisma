generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ComponentType {
  CPU
  MOTHERBOARD
  MEMORY
  STORAGE
  GPU
  PSU
}

enum MemoryType {
  DDR4
  DDR5
}

enum StorageInterface {
  M2_NVME
  SATA
}

model Product {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  brand         String
  description   String
  image         String
  stock         Int            @default(0)
  priceCents    Int
  componentType ComponentType
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  cpuSpec         CpuSpec?
  motherboardSpec MotherboardSpec?
  memorySpec      MemorySpec?
  storageSpec     StorageSpec?
  gpuSpec         GpuSpec?
  psuSpec         PsuSpec?
  cartItems       CartItem[]
}

model CpuSpec {
  productId String @id
  socket    String
  cores     Int
  threads   Int
  tdpWatts  Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model MotherboardSpec {
  productId   String     @id
  socket      String
  memoryType  MemoryType
  maxMemoryGb Int
  m2Slots     Int
  sataPorts   Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model MemorySpec {
  productId   String     @id
  memoryType  MemoryType
  speedMhz    Int
  capacityGb  Int
  modules     Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model StorageSpec {
  productId   String           @id
  interface   StorageInterface
  capacityGb  Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model GpuSpec {
  productId String @id
  vramGb    Int
  tdpWatts  Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PsuSpec {
  productId   String @id
  wattage     Int
  efficiency  String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Cart {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model FaqEntry {
  id        String   @id @default(cuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
}